<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"></requires>
  <object class="GtkBox" id="item">
    <style>
      <class name="item-box"></class>
    </style>
    <property name="orientation">horizontal</property>
    <child>
      <object class="GtkImage" id="icon">
        <style>
          <class name="item-image"></class>
        </style>
        <property name="pixel-size">32</property>
      </object>
    </child>
    <child>
      <object class="GtkBox" id="text_box">
        <style>
          <class name="item-text-box"></class>
        </style>
        <property name="orientation">vertical</property>
        <property name="valign">center</property>
        <child>
          <object class="GtkLabel" id="title">
            <style>
              <class name="item-text"></class>
            </style>
            <property name="halign">start</property>
          </object>
        </child>
        <child>
          <object class="GtkLabel" id="sub">
            <style>
              <class name="item-subtext"></class>
            </style>
            <property name="halign">start</property>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
